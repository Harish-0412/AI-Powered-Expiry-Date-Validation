# ──────────────────────────────────────────────────────────────
# Phase 2 Backend — Environment Configuration
# Copy to .env and fill in values. Never commit .env.
# ──────────────────────────────────────────────────────────────

# PostgreSQL via Docker (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://expiry_user:expiry_pass@localhost:5432/expiry_db

# Application
APP_ENV=development
APP_VERSION=2.0.0
SECRET_KEY=change_this_secret_key_phase2

# File storage (local path for product images in development)
UPLOAD_DIR=./uploads

# ML team webhook (called when a batch is ready for prediction)
# Leave blank until ML team provides an endpoint
ML_WEBHOOK_URL=
