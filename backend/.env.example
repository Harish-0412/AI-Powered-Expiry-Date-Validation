# ──────────────────────────────────────────────────────────────
# AI-Powered Expiry Date Validation — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ──────────────────────────────────────────────────────────────

# Database connection string
# SQLite (local development):
DATABASE_URL=sqlite:///./expiry_validation.db
# PostgreSQL (staging / production):
# DATABASE_URL=postgresql://user:password@localhost:5432/expiry_db

# JWT secret key — generate a strong key:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_secret_key

# JWT token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Shelf-life decision thresholds (days)
#   remaining_days > WARNING_DAYS            → ACCEPTED
#   REJECT_DAYS <= remaining_days <= WARNING → PRIORITY_SALE
#   remaining_days < REJECT_DAYS             → REJECTED
WARNING_DAYS=60
REJECT_DAYS=30

# Runtime environment: development | staging | production
# Tables are auto-created (create_all) only in development mode.
# Use Alembic migrations for staging and production.
APP_ENV=development
